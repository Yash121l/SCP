{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "COOKIE_SECRET",
    "DATABASE_URL",
    "FRONTEND_ORIGIN",
    "JWT_SECRET",
    "NODE_ENV",
    "PORT",
    "VITE_API_BASE_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    }
  }
}
