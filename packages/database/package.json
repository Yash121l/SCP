{
  "name": "@scp/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@scp/contracts": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.32",
    "@types/pg": "^8.15.4",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}

