{
  "name": "@scp/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed": "tsx src/seed.ts",
    "docker:dev": "npm run seed && npm run dev",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "pg": "^8.16.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "@types/pg": "^8.15.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
