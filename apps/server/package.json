{
  "name": "@scp/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "pnpm --filter @scp/contracts build && pnpm --filter @scp/database build && tsx watch src/main.ts",
    "smoke": "pnpm --filter @scp/contracts build && pnpm --filter @scp/database build && tsx src/smoke.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@scp/contracts": "workspace:*",
    "@scp/database": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.3.3",
    "jose": "^5.10.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.32",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
