{
  "name": "@scp/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "dev": "pnpm --filter @scp/contracts build && pnpm --filter @scp/ui build && vite --host 0.0.0.0 --port 5173",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@scp/contracts": "workspace:*",
    "@scp/ui": "workspace:*",
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^0.564.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.8.3"
  }
}
